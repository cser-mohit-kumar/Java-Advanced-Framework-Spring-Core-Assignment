<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    
    <bean  
    
    class="com.capgemini.java_advanced.framework.spring.core.Product"
    id ="product1">
    <constructor-arg index="0" value="3" />
    <constructor-arg index="1" value="apsara"/>
    <constructor-arg index="2" value="23"/>
    </bean>
    
    <bean class="com.capgemini.java_advanced.framework.spring.core.Student"
    	id="student1">
    	
    	<property name="id" value="1"/>
    	<property name="name" value="r"/>
    	<property name="mailId" value="r@mail.com"/>
    	<property name="product" ref="product1"></property>
    </bean>
    

</beans>